    <string name="accessibility_lock_description">Umožní aplikácii CleanPhoneLauncher zamknúť obrazovku dvojitým ťuknutím na domovskú obrazovku. Zamyká ako tlačidlo napájania, takže odomknutie odtlačkom prsta naďalej funguje.</string>
